{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "baseBranches": ["main"],
  "extends": ["config:best-practices", ":semanticCommitTypeAll(chore)"],
  "labels": ["dependencies"],
  "osvVulnerabilityAlerts": true,
  "schedule": ["before 4am on monday"],
  "timezone": "America/Costa_Rica",
  "prConcurrentLimit": 5,
  "prHourlyLimit": 2,
  "prCreation": "not-pending",
  "platformAutomerge": true,
  "packageRules": [
    {
      "description": "Pin GitHub Actions to full SHA — Renovate keeps them current",
      "matchManagers": ["github-actions"],
      "pinDigests": true
    },
    {
      "automerge": true,
      "automergeType": "pr",
      "description": "Automerge GitHub Actions minor/patch/digest updates",
      "matchManagers": ["github-actions"],
      "matchUpdateTypes": ["minor", "patch", "digest"]
    },
    {
      "automerge": true,
      "automergeType": "pr",
      "description": "Automerge pip patch updates",
      "matchManagers": ["pip_requirements", "pip-compile", "pipenv"],
      "matchUpdateTypes": ["patch"]
    },
    {
      "dependencyDashboardApproval": true,
      "description": "Require approval for all major updates",
      "matchUpdateTypes": ["major"]
    }
  ],
  "vulnerabilityAlerts": {
    "automerge": true,
    "enabled": true,
    "labels": ["security", "dependencies"],
    "prCreation": "immediate",
    "prPriority": 10
  }
}
